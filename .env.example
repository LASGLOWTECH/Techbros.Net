# Supabase (required for auth and data)
# Get these from your project: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Public contact page (optional — defaults to hello@techbros.network)
# VITE_CONTACT_EMAIL=support@yourdomain.com

# ---------------------------------------------------------------------------
# Admin email alerts (registration, newsletter, contact form)
# ---------------------------------------------------------------------------
# WHERE: Run commands in PowerShell / Terminal on your PC — NOT inside this .env file.
#        Folder: any (often your project root, e.g. techbrosnetwork).
#        First time:  supabase login
#                     supabase link --project-ref <same as VITE_SUPABASE_PROJECT_ID>
#        Alternative: Dashboard → Project Settings → Edge Functions → Secrets (same names/values).
#
# Not the same as Vite/Nodemailer .env: mail runs on Supabase; never put SMTP passwords in VITE_*.
#
# Example Gmail SMTP (replace with your real email + Google “App password”):
#   supabase secrets set ADMIN_NOTIFY_WEBHOOK_SECRET=K8mNp2xQv9wR4tY7zL1jH6fD0sA3bC5e
#   supabase secrets set SMTP_HOST=smtp.gmail.com
#   supabase secrets set SMTP_PORT=465
#   supabase secrets set EMAIL_USER=you@gmail.com
#   supabase secrets set EMAIL_PASSWORD="abcd efgh ijkl mnop"
#   supabase secrets set ADMIN_NOTIFICATION_EMAIL=you@gmail.com
#   supabase functions deploy admin-notify
# (WEBHOOK_SECRET: any long random string YOU invent; use the SAME value in Database Webhooks → Authorization: Bearer ...)
#
# Always set on Supabase:
#   ADMIN_NOTIFY_WEBHOOK_SECRET=<long-random-string>
#
# Pick ONE sending method:
#
# A) Resend (HTTP API — no SMTP host/port)
#   supabase secrets set RESEND_API_KEY=re_xxxxxxxx
#   supabase secrets set ADMIN_NOTIFICATION_EMAIL=you@example.com
#
# B) SMTP (same idea as EMAIL_USER + EMAIL_PASSWORD + port in your other apps)
#   supabase secrets set SMTP_HOST=smtp.gmail.com
#   supabase secrets set SMTP_PORT=465
#   supabase secrets set SMTP_USER=you@gmail.com
#   supabase secrets set SMTP_PASS=your-app-password
#   supabase secrets set ADMIN_NOTIFICATION_EMAIL=you@gmail.com
#   Or use names from your other project (aliases supported):
#   supabase secrets set EMAIL_USER=you@gmail.com
#   supabase secrets set EMAIL_PASSWORD=your-app-password
#   supabase secrets set EMAIL_PORT=465
#   (If ADMIN_NOTIFICATION_EMAIL is unset, EMAIL_USER is used as the inbox to notify.)
#
# ADMIN_EMAIL / ADMIN_PASSWORD in other apps are usually *login to your app*, not SMTP —
# they are not read by admin-notify unless you map them yourself to SMTP_* / EMAIL_*.
#
# Then:  supabase functions deploy admin-notify
# Webhooks (Dashboard → Database → Webhooks), INSERT only, POST to:
#   https://<project-ref>.supabase.co/functions/v1/admin-notify
# Header: Authorization = Bearer <ADMIN_NOTIFY_WEBHOOK_SECRET>
# Tables: public.profiles, public.newsletter_subscribers, public.contact_submissions
#
# Details: supabase/functions/admin-notify/index.ts
